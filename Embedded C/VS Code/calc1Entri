void add(int a, int b) {
    int sum;
    sum = a + b;
    printf("The sum of two numbers is %d", sum);
}
void sub(int a, int b) {
    int diff;
    diff = a - b;
    printf("\nThe difference of two numbers is %d", diff);
}
void mul(int a, int b) {
    int product;
    product = a * b;
    printf("\nThe product of two numbers is %d", product);
}
void divd(int a, int b) {
    int division;
    division = a / b;
    printf("\nThe division of two numbers is %d", division);
}
int main() {
    int num1, num2;
    int result;
    printf("Enter your first number: ");
    scanf("%d", &num1);
    printf("Enter your second number: ");
    scanf("%d", &num2);
    add(num1, num2);
    sub(num1, num2);
    mul(num1, num2);
    divd(num1, num2);
    
    return 0;
}